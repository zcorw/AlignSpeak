# Required secrets
JWT_SECRET=replace-with-a-long-random-secret
POSTGRES_PASSWORD=replace-with-a-strong-password
DATABASE_URL=postgresql+psycopg://alignspeak:replace-with-a-strong-password@db:5432/alignspeak
OPENAI_API_KEY=replace-with-openai-api-key
BOOTSTRAP_ADMIN_KEY=replace_with_bootstrap_admin_key

# Optional application settings
OCR_PROVIDER=openai
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_OCR_MODEL=gpt-4.1-mini
OPENAI_OCR_TIMEOUT_SECONDS=45
STT_PROVIDER=openai
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_TIMEOUT_SECONDS=120
OPENAI_MONTHLY_BUDGET_USD=10
OPENAI_BUDGET_ALERT_THRESHOLD_USD=8
OPENAI_BUDGET_HARD_STOP_USD=9.5
ACCESS_TOKEN_EXPIRE_SECONDS=43200

# Optional bind ports for host nginx upstreams
WEB_PORT=8080
API_PORT=8000
DB_ADMIN_PORT=18080
