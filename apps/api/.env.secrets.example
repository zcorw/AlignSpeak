# Copy this file to `.env.secrets` and fill real values.
# `.env.secrets` is git-ignored.

# API auth secret
JWT_SECRET=replace_with_secure_jwt_secret
BOOTSTRAP_ADMIN_KEY=replace_with_bootstrap_admin_key

# Database secret and DSN (password must match in both entries)
POSTGRES_PASSWORD=replace_with_db_password
DATABASE_URL=postgresql+psycopg://alignspeak:replace_with_db_password@db:5432/alignspeak

# OCR provider secret
OPENAI_API_KEY=replace_with_openai_api_key
OPENAI_MONTHLY_BUDGET_USD=10
OPENAI_BUDGET_ALERT_THRESHOLD_USD=8
OPENAI_BUDGET_HARD_STOP_USD=9.5
